              name="Presupuestación"
              web_icon="partyon_presupuestacion,static/description/icon.png"
              sequence="25"/>

    <!-- Submenú: Presupuestos -->
    <menuitem id="partyon_menu_estimates"
              name="Presupuestos"
              parent="partyon_menu_root"
              sequence="10"/>

    <menuitem id="partyon_menu_estimate_list"
              name="Presupuestos internos"
              parent="partyon_menu_estimates"
              action="partyon_estimate_action"
              sequence="10"/>

    <!-- Submenú: Configuración (para futuras opciones) -->
    <menuitem id="partyon_menu_config"
              name="Configuración"
              parent="partyon_menu_root"
              groups="group_partyon_manager"
              sequence="90"/>

</odoo>

